# ─────────────────────────────────────────────────────────────────
# .env.example — copy to .env.dev for local development
# NEVER commit .env.dev, .env.test or .env — they are gitignored
# ─────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────
# Standard postgresql:// URL — the psycopg v3 driver is wired automatically
# in database.py (_normalise_db_url). No need for postgresql+psycopg:// here.
# Dev (Steps 1–13): Postgres runs locally in Docker
DATABASE_URL=postgresql://atd:dev_password@localhost:5432/atd_dev

# Test: copy to .env.test — points to atd_test DB (see conftest.py)
# DATABASE_URL=postgresql://atd:dev_password@localhost:5432/atd_test

# After Step 14 (Dell prod):
# DATABASE_URL=postgresql://atd:<password>@<db_host>:5432/atd_prod

# ── App ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-secrets-token-hex-32
ENCRYPTION_KEY=change-me-32-char-aes-key-hex

# ── Environment ─────────────────────────────────────────────────
ENVIRONMENT=development
# Values: development | test | production

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Dev default (Vite): http://localhost:5173,http://127.0.0.1:5173
# Production example: https://myapp.example.com
ALLOWED_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173

# ── Postgres (for docker-compose.dev.yml service) ───────────────
POSTGRES_DB=atd_dev
POSTGRES_USER=atd
POSTGRES_PASSWORD=dev_password

# ── Timezone ────────────────────────────────────────────────────
# IANA timezone name used for Telegram notification timestamps.
# Default: UTC. Set to your local timezone for readable alert times.
# Example: Europe/Paris | America/New_York | Asia/Tokyo
APP_TIMEZONE=UTC

# ── Logging ─────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR  (default: INFO)
# Dev: DEBUG recommended — prod: INFO
LOG_LEVEL=INFO
# LOG_DIR: directory for log files (prod only — ignored in dev)
# In prod Docker, bind-mounted to /srv/atd/logs/app on the Dell
# LOG_DIR=/app/logs
